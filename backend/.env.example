# Backend Environment Variables

# Django Settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_ENGINE=django.db.backends.mysql
DB_NAME=cfp_db
DB_USER=cfp_user
DB_PASSWORD=cfp_password
DB_HOST=localhost
DB_PORT=3306

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Configuration
SIMPLE_JWT_ACCESS_HOURS=2
SIMPLE_JWT_REFRESH_DAYS=1

# Cache Configuration (Redis)
CACHE_BACKEND=django_redis.cache.RedisCache
CACHE_LOCATION=redis://127.0.0.1:6379/1

# Analytics Cache TTL (seconds)
ANALYTICS_CACHE_SECONDS=300

# Email (SMTP) Configuration - General / Terciario
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CFP <soporte@lucasoviedodev.org>
CFP_FROM_EMAIL=Centro de Formación Profesional <estudiantes.cfp@malvinastdf.edu.ar>
TERCIARIO_FROM_EMAIL=Tecnicatura Superior - Politécnico <inscripciones@politecnico.ar>

# Email (SMTP) Configuration - CFP Specific (Google Workspace)
CFP_EMAIL_HOST=smtp.gmail.com
CFP_EMAIL_PORT=587
CFP_EMAIL_USE_TLS=True
CFP_EMAIL_USE_SSL=False
CFP_EMAIL_HOST_USER=your-cfp-email@gmail.com
CFP_EMAIL_HOST_PASSWORD=your-cfp-app-password

# Frontend and URLs
FRONTEND_URL=https://cfp.lucasoviedodev.org

# Google reCAPTCHA v3 Configuration
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

